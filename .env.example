# Configuración de variables de entorno para producción
# Copiar este archivo a .env y rellenar con valores reales

# Puerto de la aplicación
PORT=8080

# JWT Secret (debe ser una cadena Base64 de al menos 256 bits)
JWT_SECRET=dG9zYWlyLXNlY3JldC1rZXktbXVzdC1iZS1hdC1sZWFzdC0yNTYtYml0cy1sb25nLWZvci1IUzI1Ng==

# CORS - Origins permitidos (OBLIGATORIO en producción)
# Reemplazar con la URL real del frontend en producción
# Ej: https://mi-app.com,https://www.mi-app.com
CORS_ALLOWED_ORIGINS=https://mi-app.com

# Base de datos
SPRING_DATASOURCE_URL=jdbc:mysql://host:port/database
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=password
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# Redis - URL completa
REDIS_URL=redis://:password@host:port

# RabbitMQ (opcional)
SPRING_RABBITMQ_HOST=rabbitmq.example.com
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

